# Spring Profile
SPRING_PROFILES_ACTIVE=local

# Provider 开关（本地默认走安全的 mock/log/local 实现）
APP_MEDIA_STORAGE_PROVIDER=local
APP_AUTH_PASSWORD_RESET_PROVIDER=log
APP_AUTH_SMS_PROVIDER=log
APP_LLM_PROVIDER=mock
APP_PUSH_PROVIDER=log
APP_MODERATION_PROVIDER=passthrough
APP_ANALYTICS_PROVIDER=log
# APP_ANALYTICS_UMENG_APP_KEY=
# APP_ANALYTICS_UMENG_APP_MASTER_SECRET=

# 阿里云OSS配置（头像 / 树洞图片等媒体存储）
# 重要：不要提交真实的凭据！请将真实值保存在本地的.env文件中
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_OSS_BUCKET_NAME=goaway-media
# 可选：如果使用CDN加速，配置CDN域名
# ALIYUN_OSS_CDN_DOMAIN=your-cdn-domain.com

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/goaway_db
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=replace_with_strong_password

# JWT密钥
APP_JWT_SECRET=replace_with_a_long_random_secret_key
APP_JWT_EXPIRATION_MS=2592000000

# 大模型配置（AI 周报 / 毒鸡汤 / 骂老板等场景，经 LlmSceneConfig 路由）
# 首版默认 mock；切换到 OpenAI-compatible provider（如 deepseek）时补齐下面项。
APP_LLM_OPENAI_BASE_URL=https://api.openai.com
APP_LLM_OPENAI_API_KEY=your_openai_api_key_here
APP_LLM_OPENAI_CHAT_MODEL=gpt-4o-mini

# 推送配置（喝水 / 久坐 / 下班提醒）
# 本地默认 log；生产切换到 apns 或阿里云 EMAS 时补齐凭据。
# APP_PUSH_APNS_KEY_ID=
# APP_PUSH_APNS_TEAM_ID=
# APP_PUSH_APNS_BUNDLE_ID=com.goaway.app

# 内容审核配置（mood 树洞 UGC）
# 本地默认 passthrough；生产切换到阿里云内容安全时补齐凭据。
# APP_MODERATION_ALIYUN_ACCESS_KEY_ID=
# APP_MODERATION_ALIYUN_ACCESS_KEY_SECRET=

# 密码找回邮箱配置
# 腾讯企业邮箱常见配置示例：
# SPRING_MAIL_HOST=smtp.exmail.qq.com
# SPRING_MAIL_PORT=465
# SPRING_MAIL_USERNAME=no-reply@example.com
# SPRING_MAIL_PASSWORD=replace_with_mailbox_password_or_client_authorization_code
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_SSL_ENABLE=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
# APP_MAIL_FROM_ADDRESS=no-reply@example.com
# APP_MAIL_FROM_NAME=goaway
# APP_MAIL_REPLY_TO=support@example.com

# 短信登录配置
# 当前后端会读取 provider / sign-name / 短信模板码。
# 如果你接入阿里云短信 SDK，请同时准备下面的标准凭据与 endpoint。
APP_AUTH_SMS_ALIYUN_SIGN_NAME=your_sms_sign_name
APP_AUTH_SMS_ALIYUN_LOGIN_TEMPLATE_CODE=your_login_template_code
APP_AUTH_SMS_ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
APP_AUTH_SMS_ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here
APP_AUTH_SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com

# Apple 登录
APP_APPLE_BUNDLE_ID=com.goaway.app

# CORS 与文档
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_DOCS_ENABLED=true

# 服务监听
SERVER_PORT=8080
SERVER_ADDRESS=127.0.0.1

# 日志
APP_LOG_LEVEL=INFO
APP_SECURITY_LOG_LEVEL=WARN

# 图片压缩配置
APP_IMAGE_COMPRESSION_MAX_WIDTH=1200
APP_IMAGE_COMPRESSION_MAX_HEIGHT=1200
APP_IMAGE_COMPRESSION_QUALITY=0.8
APP_IMAGE_COMPRESSION_ENABLED=true
