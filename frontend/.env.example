# Frontend runtime examples
APP_REMOTE_API_BASE_URL=https://api.what-to-eat.example.com
APP_REMOTE_PROXY_TARGET=https://api.what-to-eat.example.com

# Optional override when device local mode cannot auto-detect LAN IP
LOCAL_LAN_IP=

# Optional overrides for iPhone device builds.
# Use your own Apple Developer team and a unique bundle id if the default
# release signing settings do not belong to your local Apple account.
IOS_DEVELOPMENT_TEAM=
IOS_APP_BUNDLE_ID=com.example.whattoeat.dev

# 真机 remote 联调前，请先在 Xcode 中用同一 Team + Bundle Identifier
# 对真机点一次 Run，确保 Apple Development 证书和 provisioning profile
# 已同步到本机。仅有 Apple Distribution 证书不足以支持 run-ios 安装真机。
